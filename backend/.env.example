# ─── Database ────────────────────────────────────────────────────────────
# Neon Postgres connection string. Use the POOLED endpoint URL.
# Get it from: neon.tech → Project → Connection Details → Pooled connection
NEON_DATABASE_URL=postgresql://user:pwd@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Argon2 pepper (highly recommended for production) ───────────────────
# Argon2's `secret` parameter (RFC 9106). Mixed into hashes; needed for verify.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# In production: load from a secrets manager, NOT from env on the host.
ARGON2_PEPPER=

# ─── Session signing key ─────────────────────────────────────────────────
# Used to sign session cookies. Rotation invalidates all sessions.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=

# ─── CORS ────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://portal.shionquant.com,http://localhost:5173

# ─── Cloudflare R2 (M4 — document vault) ─────────────────────────────────
# All four required for upload / download endpoints to work. List / metadata
# endpoints work without R2; only file-bytes operations need it.
#
# Get these from: Cloudflare → R2 → API tokens → Manage R2 API Tokens
#   - R2_ENDPOINT     = https://<account-id>.r2.cloudflarestorage.com
#   - R2_BUCKET       = name of your R2 bucket (must already exist)
#   - R2_ACCESS_KEY   = R2 token access-key-id
#   - R2_SECRET_KEY   = R2 token secret-access-key
# AWS S3 also works — set R2_ENDPOINT to the regional S3 endpoint and use
# AWS access/secret keys.
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
R2_BUCKET=shion-quant-docs
R2_ACCESS_KEY=
R2_SECRET_KEY=
# Optional: R2 bucket region (defaults to "auto" for Cloudflare R2).
R2_REGION=auto

# ─── 2FA ──────────────────────────────────────────────────────────────────
TOTP_ISSUER=Shion Quant

# ─── KYC envelope encryption (M2) ────────────────────────────────────────
# Master Key Encryption Key (KEK) — wraps per-row DEKs. 32 raw bytes, base64.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# In production: replace with AWS KMS / GCP KMS (lib/kms.ts has the swap point).
# Rotation: keeping the same KEK means keeping the same wrapped DEKs. To rotate,
# decrypt with old KEK + re-wrap with new KEK; do that as a background job.
KYC_KEK_BASE64=
# Searchable-hash site key (deterministic HMAC-SHA256 for legal_name_hash etc.).
# MUST be a different key from KYC_KEK_BASE64 — searchable encryption can leak
# frequency, so we don't want one compromise to leak both.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
KYC_SEARCH_KEY_BASE64=

# ─── Email (Phase 2) ─────────────────────────────────────────────────────
RESEND_API_KEY=
