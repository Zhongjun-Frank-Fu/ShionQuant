{
  "name": "shion-quant-backend",
  "version": "0.0.1",
  "description": "Shion Quant client portal backend — Hono + Drizzle + Neon Postgres",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "selftest:argon2": "tsx src/auth/argon2.selftest.ts",
    "seed": "tsx src/db/seed.ts",
    "retention": "tsx src/db/retention.ts",
    "create-admins": "tsx scripts/create-admin-users.ts",
    "create-admins:sql": "tsx scripts/create-admin-sql.ts",
    "db:apply-sql": "psql \"$NEON_DATABASE_URL\" -f src/db/schema.sql",
    "db:migrate-audit-immutable": "psql \"$NEON_DATABASE_URL\" -f src/db/migrations/0001_audit_immutable.sql",
    "db:migrate-buying-power": "psql \"$NEON_DATABASE_URL\" -f src/db/migrations/0002_buying_power.sql",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@neondatabase/serverless": "^0.10.4",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.36.4",
    "hash-wasm": "^4.12.0",
    "hono": "^4.6.14",
    "otpauth": "^9.3.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250508.0",
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wrangler": "^4.0.0"
  }
}
