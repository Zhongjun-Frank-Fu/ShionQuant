{
  "name": "shion-quant-backend",
  "version": "0.0.1",
  "description": "Shion Quant client portal backend — Hono + Drizzle + Neon Postgres",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "sync-frontend": "node scripts/sync-frontend.mjs",
    "dev": "pnpm run sync-frontend && wrangler dev",
    "deploy": "pnpm run sync-frontend && wrangler deploy",
    "deploy:secrets": "node scripts/push-secrets.mjs",
    "selftest:argon2": "tsx src/auth/argon2.selftest.ts",
    "seed": "tsx src/db/seed.ts",
    "retention": "tsx src/db/retention.ts",
    "create-admins": "tsx scripts/create-admin-users.ts",
    "create-admins:sql": "tsx scripts/create-admin-sql.ts",
    "db:apply-sql": "node scripts/db-exec.mjs src/db/schema.sql",
    "db:migrate-audit-immutable": "node scripts/db-exec.mjs src/db/migrations/0001_audit_immutable.sql",
    "db:migrate-buying-power": "node scripts/db-exec.mjs src/db/migrations/0002_buying_power.sql",
    "db:migrate-reports-category-metadata": "node scripts/db-exec.mjs src/db/migrations/0003_reports_category_metadata.sql",
    "db:migrate-documents-folded-metadata": "node scripts/db-exec.mjs src/db/migrations/0004_documents_folded_metadata.sql",
    "db:migrate-profile-extended": "node scripts/db-exec.mjs src/db/migrations/0005_profile_extended.sql",
    "db:migrate-custom-projects-metadata": "node scripts/db-exec.mjs src/db/migrations/0006_custom_projects_metadata.sql",
    "db:migrate-calendar-preferences": "node scripts/db-exec.mjs src/db/migrations/0007_calendar_preferences.sql",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@neondatabase/serverless": "^0.10.4",
    "@noble/hashes": "^2.2.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.14",
    "otpauth": "^9.3.5",
    "pdf-lib": "^1.17.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250508.0",
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wrangler": "^4.0.0"
  }
}
