{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    // The Worker runtime + Node compat layer give us both globals at runtime;
    // both type packages are compatible. Node types cover `node:crypto` /
    // `Buffer` etc that lib/kms.ts uses; workers-types covers `ExecutionContext`,
    // `Request`/`Response` augmentations, `crypto.getRandomValues`, etc.
    // Standalone Node scripts (seed.ts / retention.ts) only use Node APIs.
    "types": ["node", "@cloudflare/workers-types"],

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": false,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,

    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
